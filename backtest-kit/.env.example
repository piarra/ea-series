# Data source (Dukascopy CSV or CSV.GZ file / directory)
DUKASCOPY_DATA_PATH=./data/dukascopy
DUKASCOPY_DEFAULT_SPREAD=0

# Default symbols
DEFAULT_SYMBOL=XAUUSD
SILVER_SYMBOL=XAGUSD

# Backtest frame
BACKTEST_FRAME_START=2025-01-01T00:00:00Z
BACKTEST_FRAME_END=2025-01-31T23:59:00Z
BACKTEST_USE_PERSIST=1

# Regime and strategy tuning
REGIME_COOLING_BARS=3
NM3_TP_MULTIPLIER=1.6
NM3_SL_MULTIPLIER=1.0
SIMPLE2_MIN_RR=2.1
SINGLE2_SWING_TRAIL_DISTANCE_RATIO=0.55
SINGLE2_SWING_TP_MULTIPLIER=12

# Trading stop windows in UTC (comma separated, HH:MM-HH:MM)
BLACKOUT_WINDOWS=21:55-22:10

# Optional calendar file (CSV first column must be timestamp)
NEWS_CALENDAR_FILE=
NEWS_MINUTES_BEFORE=5
NEWS_MINUTES_AFTER=30

# UI + control API
CONTROL_HOST=0.0.0.0
CONTROL_PORT=60050
