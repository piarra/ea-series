{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2022",
    "checkJs": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*"]
    }
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "types/**/*",
    "node_modules/backtest-kit/types.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
